---
const meta = {
  title: "Jacky Yu — Technical Program Manager",
  description: "Technical Program Manager specializing in M&A security integration. Currently at Cloudflare.",
  url: "https://jackyyu.me",
};

const lastUpdated = "May 2026";
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={meta.description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={meta.url} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />

    <link rel="canonical" href={meta.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{meta.title}</title>

    <style is:global>
      @import "tailwindcss";

      :root {
        --serif: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
        --sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        --mono: ui-monospace, SFMono-Regular, "SF Mono", Consolas, monospace;
      }

      html {
        font-family: var(--sans);
        font-feature-settings: "ss01", "ss02", "cv01", "cv03";
      }

      .font-serif {
        font-family: var(--serif);
        font-feature-settings: "kern", "liga", "calt";
      }

      .font-mono {
        font-family: var(--mono);
      }

      ::selection {
        background-color: rgb(251 191 36 / 0.3);
        color: rgb(245 245 244);
      }
    </style>
  </head>

  <body class="bg-stone-950 text-stone-100 antialiased">
    <!-- Sticky top nav -->
    <nav
      class="sticky top-0 z-50 backdrop-blur-md bg-stone-950/80 border-b border-stone-800/50"
    >
      <div
        class="max-w-3xl mx-auto px-6 py-4 flex justify-between items-center text-xs tracking-widest uppercase"
      >
        <a href="#hero" class="text-stone-100 font-serif">Jacky Yu<em class="text-amber-400">.</em></a>
        <div class="hidden md:flex gap-6 text-stone-400">
          <a href="#about" class="hover:text-amber-400 transition">About</a>
          <a href="#impact" class="hover:text-amber-400 transition">Impact</a>
          <a href="#experience" class="hover:text-amber-400 transition">Experience</a>
          <a href="#work" class="hover:text-amber-400 transition">Work</a>
          <a href="#contact" class="hover:text-amber-400 transition">Contact</a>
        </div>
      </div>
    </nav>

    <main class="max-w-3xl mx-auto px-6 py-16 md:py-24 space-y-32 md:space-y-40">
      <!-- HERO -->
      <section id="hero" class="space-y-10 md:space-y-12">
        <!-- Manifest line - never wraps, larger -->
        <p class="text-sm md:text-base tracking-[0.3em] text-stone-500 uppercase font-mono whitespace-nowrap overflow-x-auto">
          J01 · TECHNICAL PROGRAM MANAGER · AUSTIN, TEXAS
        </p>

        <!-- Floating portrait + flowing text -->
        <div class="lg:clearfix">
          <!-- Portrait floats right on desktop, stacks above on mobile -->
          <div class="relative mb-8 lg:mb-4 lg:float-right lg:ml-12 lg:w-[24rem] w-full max-w-sm mx-auto lg:mx-0">
            <img
              src="/me.jpeg"
              alt="Jacky Yu"
              class="w-full aspect-square object-cover rounded-lg border border-stone-800"
              loading="eager"
            />
            <div class="absolute top-4 left-5 right-5 flex justify-between items-baseline text-xs tracking-widest uppercase font-mono pointer-events-none">
              <span class="text-stone-950 font-bold">FIG. 01 / J. YU</span>
              <span class="text-stone-950 font-bold">2026</span>
            </div>
          </div>

          <!-- Headline + tagline + CTAs: text flows around floated portrait -->
          <div class="space-y-8 md:space-y-10">
            <h1
              class="text-4xl md:text-5xl lg:text-[3.5rem] font-serif leading-[1.05] tracking-tight"
            >
              Delivering value at the <em
                class="italic text-amber-400">crossroads</em
              > of AI, automation &amp; operations.
            </h1>

            <p class="text-base md:text-lg text-stone-300 leading-relaxed font-mono">
              Force multiplier and Technical Program Manager with 8+ years leading digital transformation, integrating AI acquisitions, and turning chaos into compounding momentum. Currently at Cloudflare.
            </p>

            <div class="flex flex-wrap gap-4 pt-2">
              <a
                href="#contact"
                class="bg-stone-100 text-stone-950 px-6 py-3 hover:bg-amber-400 transition text-sm tracking-wide font-mono"
              >
                Get in touch →
              </a>
              <a
                href="#work"
                class="border border-stone-700 text-stone-200 px-6 py-3 hover:border-amber-400 hover:text-amber-400 transition text-sm tracking-wide font-mono"
              >
                Where I&rsquo;ve worked
              </a>
            </div>
          </div>
        </div>
      </section>
      <!-- § 01 ABOUT -->
      <section id="about" class="pt-12 border-t border-stone-800">
        <div class="grid grid-cols-1 md:grid-cols-[12rem_1fr] gap-6 md:gap-12">
          <!-- Left column: section label -->
          <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono pt-2">
            § 01 — About
          </p>
          <!-- Right column: heading + content -->
          <div class="space-y-8">
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight">
              Eight years of turning complex <em class="italic text-amber-400">programs</em> into compounding outcomes.
            </h2>
            <div class="space-y-5 text-stone-300 leading-relaxed">
              <p>
                I&rsquo;m a Force Multiplier and Technical Program Manager working at the intersection of AI, automation &amp; operations. My 8+ years of experience includes integrating cutting edge AI acquisitions and bootstrapping the Core Cyber AI division at Cloudflare, pioneering digital transformation at Straumann Group, and overhauling operational excellence at FedEx. I previously led a life as an Industrial Engineer where I leaned into Lean, specializing in always improving and continually getting better.
              </p>
              <p>
                A few things I care about deeply: fostering great relationships and building high performing teams, seeking to understand the &ldquo;Why&rdquo; to drive the &ldquo;How,&rdquo; and moving fast in environments where clarity and outcomes are more valuable than process. I&rsquo;m inherently tool agnostic, which has allowed me to not just use tools but to utilize them. As AI transforms the digital landscape, I focus my efforts on how to deliver value in an era where the baseline capabilities of software are changing quickly.
              </p>
              <p>
                Outside of work I spend time with my best friend &amp; wife, serving at the beck and call of our golden, and filling my days with fishing, woodworking, cooking, camping, and learning.
              </p>
            </div>
          </div>
        </div>
      </section>
      <!-- § 02 IMPACT -->
      <section id="impact" class="pt-12 border-t border-stone-800">
        <div class="grid grid-cols-1 md:grid-cols-[12rem_1fr] gap-6 md:gap-12 mb-10">
          <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono pt-2">
            § 02 — Impact
          </p>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight">
            Numbers from the last <em class="italic text-amber-400">five years</em>.
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-stone-800">
          <!-- Card 1: Core Cyber AI -->
          <div class="bg-stone-950 p-8 space-y-3">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Core Cyber AI · Cloudflare
            </p>
            <p class="text-5xl md:text-6xl font-serif italic text-amber-400">
              97%
            </p>
            <p class="text-stone-300 text-sm leading-relaxed">
              Reduction in monthly AI related incidents. AI Governance institutionalized through thoughtful guard rails. Coding agents secured by default.
            </p>
          </div>

          <!-- Card 2: M&A Security -->
          <div class="bg-stone-950 p-8 space-y-3">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              M&amp;A Security · Cloudflare
            </p>
            <p class="text-5xl md:text-6xl font-serif italic text-amber-400">
              $1.5B+
            </p>
            <p class="text-stone-300 text-sm leading-relaxed">
              AI acquisitions integrated into Cloudflare&rsquo;s security perimeter. 70% (8→3 months) timeline acceleration and 80% (740→150 hours) effort reduction.
            </p>
          </div>

          <!-- Card 3: Digital Transformation -->
          <div class="bg-stone-950 p-8 space-y-3">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Digital Transformation · Straumann
            </p>
            <p class="text-5xl md:text-6xl font-serif italic text-amber-400">
              V1.0
            </p>
            <p class="text-stone-300 text-sm leading-relaxed">
              Enabled virtual patient care for Dental providers through shipping flagship mobile app. 25,000+ downloads within 6 months.
            </p>
          </div>

          <!-- Card 4: Capital Projects -->
          <div class="bg-stone-950 p-8 space-y-3">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Capital Projects · Atmos Energy
            </p>
            <p class="text-5xl md:text-6xl font-serif italic text-amber-400">
              $80M
            </p>
            <p class="text-stone-300 text-sm leading-relaxed">
              Capital portfolio executed as the company&rsquo;s first hybrid Project Manager x Engineer.
            </p>
          </div>
        </div>
      </section>
      <!-- § 03 EXPERIENCE -->
      <section id="experience" class="pt-12 border-t border-stone-800">
        <div class="grid grid-cols-1 md:grid-cols-[12rem_1fr] gap-6 md:gap-12 mb-10">
          <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono pt-2">
            § 03 — Experience
          </p>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight">
            A <em class="italic text-amber-400">chronology</em>.
          </h2>
        </div>
        <div class="space-y-12">
          <!-- Cloudflare (two nested roles) -->
          <div class="grid grid-cols-[60px_1fr] md:grid-cols-[80px_1fr] gap-4 md:gap-6">
            <img
              src="/logos/cloudflare.png"
              alt="Cloudflare logo"
              class="w-12 h-12 md:w-16 md:h-16 rounded object-contain bg-white p-1"
              loading="lazy"
            />
            <div class="space-y-3">
              <div class="flex justify-between items-baseline gap-4 flex-wrap">
                <h3 class="text-xl md:text-2xl font-serif">Cloudflare</h3>
                <p class="text-xs tracking-widest text-stone-500 font-mono whitespace-nowrap">
                  2025 — PRESENT
                </p>
              </div>
              <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
                Internet Infrastructure · Cybersecurity
              </p>

              <div class="space-y-3 text-sm pt-2">
                <div class="flex justify-between gap-4 flex-wrap">
                  <span class="text-stone-200"
                    >Technical Program Manager · Core Cyber AI</span
                  >
                  <span class="text-stone-500 font-mono text-xs whitespace-nowrap"
                    >2026 — Present</span
                  >
                </div>
                <div class="flex justify-between gap-4 flex-wrap">
                  <span class="text-stone-200"
                    >Technical Program Manager · M&amp;A Security</span
                  >
                  <span class="text-stone-500 font-mono text-xs whitespace-nowrap"
                    >2025 — 2026</span
                  >
                </div>
              </div>
            </div>
          </div>

          <!-- Straumann Group -->
          <div class="grid grid-cols-[60px_1fr] md:grid-cols-[80px_1fr] gap-4 md:gap-6">
            <img
              src="/logos/straumann.png"
              alt="Straumann Group logo"
              class="w-12 h-12 md:w-16 md:h-16 rounded object-contain bg-white p-1"
              loading="lazy"
            />
            <div class="space-y-3">
              <div class="flex justify-between items-baseline gap-4 flex-wrap">
                <h3 class="text-xl md:text-2xl font-serif">Straumann Group</h3>
                <p class="text-xs tracking-widest text-stone-500 font-mono whitespace-nowrap">
                  2022 — 2025
                </p>
              </div>
              <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
                HealthTech · Medical Devices
              </p>
              <div class="text-sm pt-2">
                <span class="text-stone-200"
                  >Program Manager · Digital Transformation</span
                >
              </div>
            </div>
          </div>

          <!-- Atmos Energy -->
          <div class="grid grid-cols-[60px_1fr] md:grid-cols-[80px_1fr] gap-4 md:gap-6">
            <img
              src="/logos/atmos.png"
              alt="Atmos Energy logo"
              class="w-12 h-12 md:w-16 md:h-16 rounded object-contain bg-white p-1"
              loading="lazy"
            />
            <div class="space-y-3">
              <div class="flex justify-between items-baseline gap-4 flex-wrap">
                <h3 class="text-xl md:text-2xl font-serif">Atmos Energy</h3>
                <p class="text-xs tracking-widest text-stone-500 font-mono whitespace-nowrap">
                  2019 — 2022
                </p>
              </div>
              <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
                Energy · Engineering, Procurement &amp; Construction
              </p>
              <div class="text-sm pt-2">
                <span class="text-stone-200"
                  >Project Manager · Capital Projects</span
                >
              </div>
            </div>
          </div>

          <!-- FedEx -->
          <div class="grid grid-cols-[60px_1fr] md:grid-cols-[80px_1fr] gap-4 md:gap-6">
            <img
              src="/logos/fedex.png"
              alt="FedEx logo"
              class="w-12 h-12 md:w-16 md:h-16 rounded object-contain bg-white p-1"
              loading="lazy"
            />
            <div class="space-y-3">
              <div class="flex justify-between items-baseline gap-4 flex-wrap">
                <h3 class="text-xl md:text-2xl font-serif">FedEx</h3>
                <p class="text-xs tracking-widest text-stone-500 font-mono whitespace-nowrap">
                  2018 — 2019
                </p>
              </div>
              <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
                Logistics · Supply Chain
              </p>
              <div class="text-sm pt-2">
                <span class="text-stone-200"
                  >Industrial Engineer</span
                >
              </div>
            </div>
          </div>
        </div>
      </section>
      <!-- § 04 PRINCIPLES -->
      <section id="principles" class="pt-12 border-t border-stone-800">
        <div class="grid grid-cols-1 md:grid-cols-[12rem_1fr] gap-6 md:gap-12 mb-10">
          <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono pt-2">
            § 04 — Principles
          </p>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight">
            What I care about as a <em class="italic text-amber-400">program leader</em>.
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 md:gap-5">
          <div class="space-y-3">
            <p class="text-stone-500 font-serif italic text-xl">i.</p>
            <h3 class="text-lg font-serif leading-snug min-h-[3.5rem]">
              Outcomes &gt; process.
            </h3>
            <p class="text-stone-400 text-sm leading-relaxed">
              Fast, focused teams ship better products and deliver tangible results.
              I sit at the intersection of structure and fluidity that keeps everyone
              on the path toward our North Star.
            </p>
          </div>
          <div class="space-y-3">
            <p class="text-stone-500 font-serif italic text-xl">ii.</p>
            <h3 class="text-lg font-serif leading-snug min-h-[3.5rem]">
              Seek to understand.
            </h3>
            <p class="text-stone-400 text-sm leading-relaxed">
              The &ldquo;Why&rdquo; before the &ldquo;How.&rdquo; Curious enough to
              dive into the technical architecture, experienced enough to know when
              to step aside. I dig until I get to the roots.
            </p>
          </div>
          <div class="space-y-3">
            <p class="text-stone-500 font-serif italic text-xl">iii.</p>
            <h3 class="text-lg font-serif leading-snug min-h-[3.5rem]">
              Strategic partner.
            </h3>
            <p class="text-stone-400 text-sm leading-relaxed">
              As the bridge between engineering, operations, and executives, I nurture
              influence rather than authority. A TPM moves the needle, but a strategic
              partner moves mountains.
            </p>
          </div>
          <div class="space-y-3">
            <p class="text-stone-500 font-serif italic text-xl">iv.</p>
            <h3 class="text-lg font-serif leading-snug min-h-[3.5rem]">
              Perfect is the enemy of done.
            </h3>
            <p class="text-stone-400 text-sm leading-relaxed">
              Relentless pursuit of perfection prevents implementing value. Chasing
              flawless execution almost always leads to bottlenecks, missed
              opportunities, or wasted efforts.
            </p>
          </div>
        </div>
      </section> 
      <!-- § 05 CONTACT -->
      <section id="contact" class="space-y-8 pt-12 border-t border-stone-800">
        <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono">
          § 05 — Contact
        </p>
        <h2 class="text-3xl md:text-4xl font-serif leading-tight">
          Get in <em class="italic text-amber-400">touch</em>.
        </h2>
        <p class="text-stone-300 max-w-xl leading-relaxed">
          Open to new opportunities and, as always, continually improving.
        </p>

        <!-- Icon buttons -->
        <div class="flex gap-4 pt-2">
          <!-- LinkedIn -->
          <a
            href="https://linkedin.com/in/jackyyu1993"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="group flex items-center justify-center w-14 h-14 rounded-full border border-stone-700 hover:border-amber-400 hover:bg-stone-900 transition"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5 text-stone-400 group-hover:text-amber-400 transition"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              />
            </svg>
          </a>

          <!-- GitHub -->
          <a
            href="https://github.com/jackyyu93"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="group flex items-center justify-center w-14 h-14 rounded-full border border-stone-700 hover:border-amber-400 hover:bg-stone-900 transition"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5 text-stone-400 group-hover:text-amber-400 transition"
            >
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
              />
            </svg>
          </a>

          <!-- Email -->
          <a
            href="mailto:jackyyu93@gmail.com"
            aria-label="Email"
            class="group flex items-center justify-center w-14 h-14 rounded-full border border-stone-700 hover:border-amber-400 hover:bg-stone-900 transition"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-stone-400 group-hover:text-amber-400 transition"
            >
              <rect x="2" y="4" width="20" height="16" rx="2" />
              <path d="m22 6-10 7L2 6" />
            </svg>
          </a>
        </div>

        <!-- Location + Availability as quiet metadata below -->
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-6 max-w-xl text-sm">
          <div>
            <dt class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Location
            </dt>
            <dd class="text-stone-300 mt-1">Austin, Texas</dd>
          </div>
          <div>
            <dt class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Availability
            </dt>
            <dd class="text-stone-300 mt-1">Open to new opportunities</dd>
          </div>
        </dl>
      </section>
    </main>

    <footer
      class="max-w-3xl mx-auto px-6 py-12 border-t border-stone-800 mt-16 flex flex-col md:flex-row justify-between gap-2 text-xs text-stone-500 tracking-widest uppercase font-mono"
    >
      <p>© 2026 · Jacky Yu · Built with care</p>
      <p>Last updated · {lastUpdated}</p>
    </footer>
  </body>
</html>