        </div>

        <!-- Location + Availability as quiet metadata below -->
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-6 max-w-xl text-sm">
          <div>
            <dt class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Location
            </dt>
            <dd class="text-stone-300 mt-1">Austin, Texas</dd>
          </div>
          <div>
            <dt class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Availability
            </dt>
            <dd class="text-stone-300 mt-1">Open to new opportunities</dd>
          </div>
        </dl>
      </section>
    </main>

    <footer
      class="max-w-3xl mx-auto px-6 py-12 border-t border-stone-800 mt-16 flex flex-col md:flex-row justify-between gap-2 text-xs text-stone-500 tracking-widest uppercase font-mono"
    >
      <p>© 2026 · Jacky Yu · Built with care</p>
      <p>Last updated · {lastUpdated}</p>
    </footer>
  </body>
</html>