---
const meta = {
  title: "Jacky Yu — Technical Program Manager",
  description: "Technical Program Manager specializing in M&A security integration. Currently at Cloudflare.",
  url: "https://jackyyu.me",
};

const lastUpdated = "May 2026";
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={meta.description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={meta.url} />
    <meta property="og:image" content="https://jackyyu.me/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Jacky Yu — Technical Program Manager" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content="https://jackyyu.me/og-image.png" />

    <link rel="canonical" href={meta.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{meta.title}</title>

    <!-- Prevent flash of wrong theme on page load -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          if (saved === 'light') {
            document.documentElement.classList.add('light');
          }
        } catch (e) {}
      })();
    </script>

    <style is:global>
      @import "tailwindcss";

      :root {
        --serif: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
        --sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        --mono: ui-monospace, SFMono-Regular, "SF Mono", Consolas, monospace;

        /* Dark theme (default) */
        --bg: #0c0a09;
        --bg-elevated: #1c1917;
        --border: #292524;
        --border-strong: #44403c;
        --text: #f5f5f4;
        --text-muted: #d6d3d1;
        --text-soft: #a8a29e;
        --text-faint: #78716c;
        --accent: #fbbf24;
        --accent-soft: rgb(251 191 36 / 0.12);
        --cta-bg: #f5f5f4;
        --cta-text: #0c0a09;
      }

      :root.light {
        --bg: #ffffff;
        --bg-elevated: #fafafa;
        --border: #e5e5e5;
        --border-strong: #d4d4d4;
        --text: #0a0a0a;
        --text-muted: #404040;
        --text-soft: #525252;
        --text-faint: #737373;
        --accent: #d97706;
        --accent-soft: rgb(217 119 6 / 0.10);
        --cta-bg: #0a0a0a;
        --cta-text: #fafafa;
      }

      html {
        font-family: var(--sans);
        font-feature-settings: "ss01", "ss02", "cv01", "cv03";
        scroll-behavior: smooth;
        scroll-padding-top: 5rem;
        background-color: var(--bg);
        color: var(--text);
        transition: background-color 300ms ease, color 300ms ease;
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
      }

      .font-serif { font-family: var(--serif); font-feature-settings: "kern", "liga", "calt"; }
      .font-mono { font-family: var(--mono); }

      ::selection { background-color: var(--accent-soft); color: var(--text); }

      /* Nav */
      .nav-bar {
        background-color: rgb(from var(--bg) r g b / 0.85);
        border-color: var(--border);
        transition: background-color 300ms ease, border-color 300ms ease;
      }
      .nav-logo { color: var(--text); transition: color 200ms ease; }
      .nav-logo:hover { color: var(--accent); }
      .nav-accent { color: var(--accent); font-style: normal; }
      .nav-link { color: var(--text-soft); transition: color 200ms ease; }
      .nav-link:hover { color: var(--accent); }

      /* CTAs */
      .cta-primary, .cta-secondary {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        font-family: var(--mono);
        font-size: 0.875rem;
        letter-spacing: 0.025em;
        transition: background-color 200ms ease, color 200ms ease, border-color 200ms ease;
      }
      .cta-primary { background-color: var(--cta-bg); color: var(--cta-text); }
      .cta-primary:hover { background-color: var(--accent); color: var(--cta-text); }
      .cta-secondary { border: 1px solid var(--border-strong); color: var(--text); }
      .cta-secondary:hover { border-color: var(--accent); color: var(--accent); }

      /* Theme toggle - pill slider */
      .theme-toggle {
        position: relative;
        display: inline-flex;
        width: 56px;
        height: 28px;
        border: 1px solid var(--border-strong);
        border-radius: 999px;
        background-color: var(--bg-elevated);
        cursor: pointer;
        transition: background-color 300ms ease, border-color 300ms ease;
        padding: 0;
        overflow: hidden;
        flex-shrink: 0;
      }
      .theme-toggle:hover { border-color: var(--accent); }
      .theme-toggle__icon {
        position: absolute;
        top: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        border-radius: 999px;
        background-color: var(--accent);
        color: var(--cta-text);
        transition: left 300ms cubic-bezier(0.5, 0, 0.2, 1), opacity 200ms ease;
        transform: translateY(-50%);
      }
      .theme-toggle__icon--sun { left: 2px; opacity: 1; }
      .theme-toggle__icon--moon { left: 2px; opacity: 0; }
      :root.light .theme-toggle__icon--sun { left: 30px; opacity: 0; }
      :root.light .theme-toggle__icon--moon { left: 30px; opacity: 1; }

      /* Rotating word effect (hero) */
      .rotating-word {
        position: relative;
        display: inline-block;
        vertical-align: baseline;
        overflow: visible;
      }
      .rotating-word__measure { visibility: hidden; white-space: nowrap; display: inline-block; }
      .rotating-word__item {
        position: absolute;
        left: 0;
        bottom: 0;
        white-space: nowrap;
        transition: transform 500ms cubic-bezier(0.5, 0, 0.5, 1), opacity 500ms ease;
      }
      .rotating-word__item--exit { transform: translateY(-100%); opacity: 0; }
      .rotating-word__item--enter { transform: translateY(100%); opacity: 0; }
      @media (prefers-reduced-motion: reduce) {
        .rotating-word__item { transition: none; }
      }

      /* Theme-aware overrides for existing Tailwind stone/amber utility classes */
      :root.light .text-stone-100 { color: var(--text) !important; }
      :root.light .text-stone-200 { color: var(--text) !important; }
      :root.light .text-stone-300 { color: var(--text-muted) !important; }
      :root.light .text-stone-400 { color: var(--text-soft) !important; }
      :root.light .text-stone-500 { color: var(--text-faint) !important; }
      :root.light .text-stone-600 { color: var(--text-faint) !important; }
      :root.light .text-stone-700 { color: var(--text-muted) !important; }
      :root.light .border-stone-700 { border-color: #9ca3af !important; }
      :root.light .border-stone-800 { border-color: #9ca3af !important; }

      /* Experience logos: visible border in both modes */
      .experience-logo {
        border: 1px solid var(--border-strong);
        background-color: #ffffff;
      }
      :root.light .bg-stone-800 { background-color: #9ca3af !important; }
      :root.light .bg-stone-900 { background-color: var(--bg-elevated) !important; }
      :root.light .bg-stone-950 { background-color: var(--bg) !important; }
      :root.light .text-amber-400 { color: var(--accent) !important; }
      :root.light .hover\:text-amber-400:hover { color: var(--accent) !important; }
      :root.light .hover\:border-amber-400:hover { border-color: var(--accent) !important; }
      :root.light .hover\:bg-amber-400:hover { background-color: var(--accent) !important; }

      /* Back-to-top floating button */
      .back-to-top {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        width: 3rem;
        height: 3rem;
        border-radius: 9999px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--bg-elevated);
        border: 1px solid var(--border-strong);
        color: var(--text-muted);
        backdrop-filter: blur(8px);
        opacity: 0;
        pointer-events: none;
        transform: translateY(8px);
        transition: opacity 250ms ease, transform 250ms ease, color 200ms ease, border-color 200ms ease;
        z-index: 40;
      }
      .back-to-top--visible {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }
      .back-to-top:hover {
        color: var(--accent);
        border-color: var(--accent);
      }
    </style>
  </head>

  <body class="antialiased" style="background-color: var(--bg); color: var(--text);">
    <!-- Sticky top nav -->
    <nav class="nav-bar sticky top-0 z-50 backdrop-blur-md border-b">
      <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center text-sm tracking-widest uppercase">
        <a href="#hero" class="nav-logo font-serif text-base">Jacky Yu<em class="nav-accent">.</em></a>
        <div class="hidden md:flex items-center gap-7">
          <!-- Theme toggle: pill slider (placed before nav links) -->
          <button
            id="theme-toggle"
            type="button"
            aria-label="Toggle light and dark mode"
            class="theme-toggle"
          >
            <span class="theme-toggle__icon theme-toggle__icon--sun">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="4"></circle>
                <path d="M12 2v2"></path>
                <path d="M12 20v2"></path>
                <path d="m4.93 4.93 1.41 1.41"></path>
                <path d="m17.66 17.66 1.41 1.41"></path>
                <path d="M2 12h2"></path>
                <path d="M20 12h2"></path>
                <path d="m6.34 17.66-1.41 1.41"></path>
                <path d="m19.07 4.93-1.41 1.41"></path>
              </svg>
            </span>
            <span class="theme-toggle__icon theme-toggle__icon--moon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
              </svg>
            </span>
          </button>

          <a href="#about" class="nav-link">About</a>
          <a href="#impact" class="nav-link">Impact</a>
          <a href="#experience" class="nav-link">Experience</a>
          <a href="#contact" class="nav-link">Contact</a>
        </div>
      </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 py-16 md:py-24 space-y-32 md:space-y-40">
      <!-- HERO -->
      <section id="hero" class="space-y-10 md:space-y-12">
        <p class="text-sm md:text-base tracking-[0.3em] uppercase font-mono whitespace-nowrap overflow-x-auto" style="color: var(--text-faint);">
          J01 · TECHNICAL PROGRAM MANAGER · AUSTIN, TEXAS
        </p>

        <div class="lg:clearfix">
          <div class="relative mb-8 lg:mb-4 lg:float-right lg:ml-12 lg:w-[24rem] w-full max-w-sm mx-auto lg:mx-0">
            <img
              src="/me.jpeg"
              alt="Jacky Yu"
              class="w-full aspect-square object-cover rounded-lg border border-stone-800"
              loading="eager"
            />
            <div class="absolute top-4 left-5 right-5 flex justify-between items-baseline text-xs tracking-widest uppercase font-mono pointer-events-none">
              <span class="text-stone-950 font-bold">FIG. 01 / J. YU</span>
              <span class="text-stone-950 font-bold">2026</span>
            </div>
          </div>

          <div class="space-y-8 md:space-y-10">
            <h1 class="font-sans font-black uppercase tracking-tight leading-[0.95] text-5xl md:text-6xl lg:text-7xl" style="color: var(--text);">Jacky Yu</h1>

            <h2 class="text-xl md:text-2xl lg:text-3xl font-serif leading-snug tracking-tight" style="color: var(--text-muted);">
              Delivering value at the crossroads of AI, automation &amp; <span class="rotating-word italic text-amber-400" aria-live="polite" aria-atomic="true"><span class="rotating-word__measure" aria-hidden="true">operations</span><span class="rotating-word__item">operations</span></span>.
            </h2>

            <p class="text-base md:text-lg leading-relaxed font-mono" style="color: var(--text-muted);">
              Force multiplier and seasoned Technical leader with 8+ years leading digital transformation, driving AI and enterprise technology initiatives, and building the foundations that let world-class teams move fast and deliver at scale. Currently at Cloudflare.
            </p>

            <div class="flex flex-wrap gap-4 pt-2">
              <a href="#contact" class="cta-primary">Get in touch →</a>
              <a href="#experience" class="cta-secondary">Where I&rsquo;ve worked</a>
            </div>
          </div>
        </div>
      </section>

      <!-- § 01 ABOUT -->
      <section id="about" class="pt-12 border-t border-stone-800">
        <div class="grid grid-cols-1 md:grid-cols-[12rem_1fr] gap-6 md:gap-12">
          <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono pt-2">
            § 01 — About
          </p>
          <div class="space-y-8">
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight">
              <em class="italic text-amber-400">Who</em> I am, <em class="italic text-amber-400">what</em> I do best, and <em class="italic text-amber-400">how</em> I live.
            </h2>
            <div class="space-y-5 text-stone-300 leading-relaxed">
              <p>
                I&rsquo;m a Force Multiplier and Technical Program Manager working at the intersection of AI, automation &amp; operations. My 8+ years of experience includes integrating cutting edge AI acquisitions and bootstrapping the Core Cyber AI division at Cloudflare, pioneering digital transformation at Straumann Group, and overhauling operational excellence at FedEx. I previously led a life as an Industrial Engineer where I leaned into Lean, specializing in always improving and continually getting better.
              </p>
              <p>
                A few things I care about deeply: fostering great relationships and building high performing teams, seeking to understand the &ldquo;Why&rdquo; to drive the &ldquo;How,&rdquo; and moving fast in environments where clarity and outcomes are more valuable than process. As AI transforms the digital landscape, I focus my efforts on how to deliver value in an era where the baseline capabilities of software are changing quickly.
              </p>
            </div>
          </div>
        </div>

        <!-- About: 3-card grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-12">

          <!-- Education -->
          <div class="about-card group p-6 rounded-lg border border-stone-800 bg-stone-900/40 transition hover:border-amber-400 hover:shadow-[0_0_0_1px_rgba(251,191,36,0.25)]">
            <div class="flex items-center gap-3 mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-stone-400 group-hover:text-amber-400 transition">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
              <p class="text-xs tracking-[0.25em] uppercase font-mono text-stone-500">Education</p>
            </div>
            <ul class="space-y-4">
              <li>
                <p class="font-serif text-base leading-snug" style="color: var(--text);">BS in Industrial Engineering</p>
                <p class="text-xs text-stone-500 font-mono mt-1">Texas Tech University</p>
              </li>
              <li>
                <p class="font-serif text-base leading-snug" style="color: var(--text);">Minor in Mathematics</p>
                <p class="text-xs text-stone-500 font-mono mt-1">Texas Tech University</p>
              </li>
            </ul>
          </div>

          <!-- Certifications -->
          <div class="about-card group p-6 rounded-lg border border-stone-800 bg-stone-900/40 transition hover:border-amber-400 hover:shadow-[0_0_0_1px_rgba(251,191,36,0.25)]">
            <div class="flex items-center gap-3 mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-stone-400 group-hover:text-amber-400 transition">
                <circle cx="12" cy="8" r="6"/>
                <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
              </svg>
              <p class="text-xs tracking-[0.25em] uppercase font-mono text-stone-500">Certifications</p>
            </div>
            <ul class="space-y-4">
              <li>
                <p class="font-serif text-sm leading-snug" style="color: var(--text);">Project Management Professional (PMP®)</p>
                <p class="text-xs text-stone-500 font-mono mt-1">PMI.org</p>
              </li>
              <li>
                <p class="font-serif text-sm leading-snug" style="color: var(--text);">Prompt Engineering for Project Managers</p>
                <p class="text-xs text-stone-500 font-mono mt-1">PMI.org</p>
              </li>
              <li>
                <p class="font-serif text-sm leading-snug" style="color: var(--text);">Generative AI Overview for Project Managers</p>
                <p class="text-xs text-stone-500 font-mono mt-1">PMI.org</p>
              </li>
              <li>
                <p class="font-serif text-sm leading-snug" style="color: var(--text);">Six Sigma Green Belt</p>
                <p class="text-xs text-stone-500 font-mono mt-1">Institute of Industrial &amp; Systems Engineers</p>
              </li>
              <li>
                <p class="font-serif text-sm leading-snug" style="color: var(--text);">Scrum Fundamentals Certified (SFC)</p>
                <p class="text-xs text-stone-500 font-mono mt-1">Vabro.ai</p>
              </li>
            </ul>
          </div>

          <!-- Fun Facts -->
          <div class="about-card group p-6 rounded-lg border border-stone-800 bg-stone-900/40 transition hover:border-amber-400 hover:shadow-[0_0_0_1px_rgba(251,191,36,0.25)]">
            <div class="flex items-center gap-3 mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-stone-400 group-hover:text-amber-400 transition">
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
              </svg>
              <p class="text-xs tracking-[0.25em] uppercase font-mono text-stone-500">Fun Facts</p>
            </div>
            <ul class="space-y-2.5 text-sm" style="color: var(--text-muted);">
              <li class="flex gap-2"><span class="text-amber-400">·</span><span>Woodworker</span></li>
              <li class="flex gap-2"><span class="text-amber-400">·</span><span>Youth-league baseball coach</span></li>
              <li class="flex gap-2"><span class="text-amber-400">·</span><span>BBQ pitmaster</span></li>
              <li class="flex gap-2"><span class="text-amber-400">·</span><span>Outdoorsman: fishing, hiking, camping</span></li>
              <li class="flex gap-2"><span class="text-amber-400">·</span><span>Bilingual: English &amp; Mandarin</span></li>
              <li class="flex gap-2"><span class="text-amber-400">·</span><span>Born in China (ask me where!)</span></li>
              <li class="flex gap-2"><span class="text-amber-400">·</span><span>Christmas Day birthday</span></li>
              <li class="flex gap-2"><span class="text-amber-400">·</span><span>Backpacked across SE Asia</span></li>
              <li class="flex gap-2"><span class="text-amber-400">·</span><span>Patent holder</span></li>
              <li class="flex gap-2"><span class="text-amber-400">·</span><span>Golden retriever dad</span></li>
              <li class="flex gap-2"><span class="text-amber-400">·</span><span>Central Austin Toastmasters</span></li>
            </ul>
          </div>

        </div>
      </section>

      <!-- § 02 IMPACT -->
      <section id="impact" class="pt-12 border-t border-stone-800">
        <div class="grid grid-cols-1 md:grid-cols-[12rem_1fr] gap-6 md:gap-12 mb-10">
          <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono pt-2">
            § 02 — Impact
          </p>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight">
            Numbers from the last <em class="italic text-amber-400">five years</em>.
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-stone-800">
          <div class="bg-stone-950 p-8 space-y-3">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Core Cyber AI · Cloudflare
            </p>
            <p class="text-5xl md:text-6xl font-serif italic text-amber-400">97%</p>
            <p class="text-stone-300 text-sm leading-relaxed">
              Reduction in monthly AI related incidents. AI Governance institutionalized through thoughtful guard rails. Coding agents secured by default.
            </p>
          </div>

          <div class="bg-stone-950 p-8 space-y-3">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              M&amp;A Security · Cloudflare
            </p>
            <p class="text-5xl md:text-6xl font-serif italic text-amber-400">$1.5B+</p>
            <p class="text-stone-300 text-sm leading-relaxed">
              AI acquisitions integrated into Cloudflare&rsquo;s security perimeter. 70% (8→3 months) timeline acceleration and 80% (740→150 hours) effort reduction.
            </p>
          </div>

          <div class="bg-stone-950 p-8 space-y-3">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Digital Transformation · Straumann Group
            </p>
            <p class="text-5xl md:text-6xl font-serif italic text-amber-400">V1.0</p>
            <p class="text-stone-300 text-sm leading-relaxed">
              Enabled virtual patient care for Dental providers through shipping flagship mobile app. 25,000+ downloads within 6 months.
            </p>
          </div>

          <div class="bg-stone-950 p-8 space-y-3">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Capital Projects · Atmos Energy
            </p>
            <p class="text-5xl md:text-6xl font-serif italic text-amber-400">$80M</p>
            <p class="text-stone-300 text-sm leading-relaxed">
              Capital portfolio executed as the company&rsquo;s first hybrid Project Manager x Engineer.
            </p>
          </div>
        </div>
      </section>

      <!-- § 03 EXPERIENCE -->
      <section id="experience" class="pt-12 border-t border-stone-800">
        <div class="grid grid-cols-1 md:grid-cols-[12rem_1fr] gap-6 md:gap-12 mb-10">
          <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono pt-2">
            § 03 — Experience
          </p>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif leading-tight">
            A <em class="italic text-amber-400">chronology</em>.
          </h2>
