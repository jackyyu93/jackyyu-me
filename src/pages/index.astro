---
const meta = {
  title: "Jacky Yu — Technical Program Manager",
  description: "Technical Program Manager specializing in M&A security integration. Currently at Cloudflare.",
  url: "https://jackyyu.me",
};

const lastUpdated = "May 2026";
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={meta.description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={meta.url} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />

    <link rel="canonical" href={meta.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{meta.title}</title>

    <style is:global>
      @import "tailwindcss";

      :root {
        --serif: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
        --sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        --mono: ui-monospace, SFMono-Regular, "SF Mono", Consolas, monospace;
      }

      html {
        font-family: var(--sans);
        font-feature-settings: "ss01", "ss02", "cv01", "cv03";
      }

      .font-serif {
        font-family: var(--serif);
        font-feature-settings: "kern", "liga", "calt";
      }

      .font-mono {
        font-family: var(--mono);
      }

      ::selection {
        background-color: rgb(251 191 36 / 0.3);
        color: rgb(245 245 244);
      }
    </style>
  </head>

  <body class="bg-stone-950 text-stone-100 antialiased">
    <!-- Sticky top nav -->
    <nav
      class="sticky top-0 z-50 backdrop-blur-md bg-stone-950/80 border-b border-stone-800/50"
    >
      <div
        class="max-w-3xl mx-auto px-6 py-4 flex justify-between items-center text-xs tracking-widest uppercase"
      >
        <a href="#hero" class="text-stone-100 font-serif">Jacky Yu<em class="text-amber-400">.</em></a>
        <div class="hidden md:flex gap-6 text-stone-400">
          <a href="#about" class="hover:text-amber-400 transition">About</a>
          <a href="#impact" class="hover:text-amber-400 transition">Impact</a>
          <a href="#experience" class="hover:text-amber-400 transition">Experience</a>
          <a href="#work" class="hover:text-amber-400 transition">Work</a>
          <a href="#contact" class="hover:text-amber-400 transition">Contact</a>
        </div>
      </div>
    </nav>

    <main class="max-w-3xl mx-auto px-6 py-16 md:py-24 space-y-32 md:space-y-40">
      <!-- HERO -->
      <section id="hero" class="space-y-8">
        <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono">
          J01 · TECHNICAL PROGRAM MANAGER · AUSTIN, TEXAS
        </p>
        <h1
          class="text-4xl md:text-6xl font-serif leading-[1.1] tracking-tight"
        >
          Delivering impact at the <em
            class="italic text-amber-400">crossroads</em
          > of AI, automation &amp; operations.
        </h1>
        <p class="text-lg md:text-xl text-stone-300 max-w-2xl leading-relaxed">
          Force multiplier masquerading as a Technical Program Manager. 8+ years bootstrapping new functions, integrating AI acquisitions, and turning chaos into compounding momentum. Currently at Cloudflare. Actively exploring what&rsquo;s next.
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <a
            href="#contact"
            class="border border-stone-700 px-6 py-3 hover:bg-stone-900 hover:border-amber-400 transition text-sm tracking-wide"
          >
            Get in touch →
          </a>
          <a
            href="#work"
            class="text-stone-400 px-6 py-3 hover:text-amber-400 transition text-sm tracking-wide"
          >
            See work
          </a>
        </div>

        <!-- Portrait placeholder -->
        <div class="pt-12">
          <div
            class="w-48 h-48 md:w-64 md:h-64 bg-stone-900 border border-stone-800 flex items-center justify-center font-serif text-6xl text-stone-700"
          >
            JY
          </div>
          <p class="text-xs tracking-widest text-stone-500 uppercase mt-3 font-mono">
            FIG. 01 / J. YU 2026
          </p>
        </div>
      </section>

      <!-- § 01 ABOUT -->
      <section id="about" class="space-y-8 pt-12 border-t border-stone-800">
        <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono">
          § 01 — About
        </p>
        <h2 class="text-3xl md:text-4xl font-serif leading-tight">
          Eight years of turning complex <em class="italic text-amber-400">programs</em> into compounding outcomes.
        </h2>
        <div class="space-y-5 text-stone-300 leading-relaxed max-w-2xl">
          <p class="text-stone-500 text-sm tracking-widest uppercase font-mono">Synopsis</p>
          <p>
            Force multiplier masquerading as a Technical Program Manager. I work at the
            crossroads of AI, automation, and operations &mdash; translating ambiguity into
            structure, and structure into shipped outcomes. Industrial Engineer by training,
            which means I see every program as a system to be measured, refined, and
            continually improved.
          </p>
          <p>
            I&rsquo;m currently at Cloudflare, where I bootstrapped the Core Cyber AI
            division and previously led security integration for cutting-edge AI
            acquisitions. Before that, I drove enterprise digital transformation at
            Straumann Group, ran capital projects across one of the fastest-growing energy
            service territories at Atmos Energy, and started my career applying Lean
            methodology to logistics operations at FedEx. The through-line: making complex
            systems work better than the day before.
          </p>
          <p>
            Outside of work, I spend time with my best friend and wife, serving at the beck
            and call of our golden, and filling my days with fishing, woodworking, cooking,
            camping, and learning whatever&rsquo;s next.
          </p>
        </div>
      </section>

      <!-- § 02 IMPACT -->
      <section id="impact" class="space-y-8 pt-12 border-t border-stone-800">
        <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono">
          § 02 — Impact
        </p>
        <h2 class="text-3xl md:text-4xl font-serif leading-tight">
          Numbers from the last <em class="italic text-amber-400">eight years</em>.
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-stone-800">
          <!-- Card 1: Core Cyber AI -->
          <div class="bg-stone-950 p-8 space-y-3">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Core Cyber AI · Cloudflare
            </p>
            <p class="text-5xl md:text-6xl font-serif italic text-amber-400">
              97%
            </p>
            <p class="text-stone-300 text-sm leading-relaxed">
              Reduction in monthly P0/P1 security incidents through institutionalized
              AI governance, thoughtful guardrails, and secure-by-default coding
              workflows.
            </p>
          </div>

          <!-- Card 2: M&A Security -->
          <div class="bg-stone-950 p-8 space-y-3">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              M&amp;A Security · Cloudflare
            </p>
            <p class="text-5xl md:text-6xl font-serif italic text-amber-400">
              $1.5B
            </p>
            <p class="text-stone-300 text-sm leading-relaxed">
              AI acquisitions integrated into Cloudflare&rsquo;s security perimeter
              &mdash; significantly accelerated timeline and reduced effort vs.
              baseline.
            </p>
          </div>

          <!-- Card 3: Digital Transformation -->
          <div class="bg-stone-950 p-8 space-y-3">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Digital Transformation · Straumann
            </p>
            <p class="text-5xl md:text-6xl font-serif italic text-amber-400">
              25K+
            </p>
            <p class="text-stone-300 text-sm leading-relaxed">
              Downloads in six months for the flagship mobile app &mdash; enabled
              virtual patient care for dental providers globally.
            </p>
          </div>

          <!-- Card 4: Capital Projects -->
          <div class="bg-stone-950 p-8 space-y-3">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              Capital Projects · Atmos Energy
            </p>
            <p class="text-5xl md:text-6xl font-serif italic text-amber-400">
              $80M
            </p>
            <p class="text-stone-300 text-sm leading-relaxed">
              Capital project portfolio executed across the fastest-growing service
              territory &mdash; the company&rsquo;s first hybrid Project Manager
              &times; Engineer role.
            </p>
          </div>
        </div>
      </section>

      <!-- § 03 EXPERIENCE -->
      <section id="experience" class="space-y-8 pt-12 border-t border-stone-800">
        <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono">
          § 03 — Experience
        </p>
        <h2 class="text-3xl md:text-4xl font-serif leading-tight">
          A <em class="italic text-amber-400">chronology</em>.
        </h2>
        <div class="space-y-12">
          <!-- Cloudflare (two nested roles) -->
          <div class="grid grid-cols-[60px_1fr] md:grid-cols-[80px_1fr] gap-4 md:gap-6">
            <img
              src="/logos/cloudflare.png"
              alt="Cloudflare logo"
              class="w-12 h-12 md:w-16 md:h-16 rounded object-contain bg-white p-1"
              loading="lazy"
            />
            <div class="space-y-3">
              <div class="flex justify-between items-baseline gap-4 flex-wrap">
                <h3 class="text-xl md:text-2xl font-serif">Cloudflare</h3>
                <p class="text-xs tracking-widest text-stone-500 font-mono whitespace-nowrap">
                  2025 — PRESENT
                </p>
              </div>
              <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
                Internet Infrastructure · Cybersecurity
              </p>

              <div class="space-y-4 text-sm pt-2">
                <div>
                  <div class="flex justify-between gap-4 flex-wrap">
                    <span class="text-stone-200"
                      >Technical Program Manager · Core Cyber AI</span
                    >
                    <span class="text-stone-500 font-mono text-xs whitespace-nowrap"
                      >2026 — Present</span
                    >
                  </div>
                  <p class="text-stone-400 leading-relaxed mt-1">
                    Bootstrapped the Core Cyber AI division, building the
                    program foundation for AI-native security at internet
                    scale.
                  </p>
                </div>

                <div>
                  <div class="flex justify-between gap-4 flex-wrap">
                    <span class="text-stone-200"
                      >Technical Program Manager · M&amp;A Security</span
                    >
                    <span class="text-stone-500 font-mono text-xs whitespace-nowrap"
                      >2025 — 2026</span
                    >
                  </div>
                  <p class="text-stone-400 leading-relaxed mt-1">
                    Led security integration for cutting-edge AI acquisitions,
                    onboarding new teams and capabilities into Cloudflare&rsquo;s
                    security perimeter.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Straumann Group -->
          <div class="grid grid-cols-[60px_1fr] md:grid-cols-[80px_1fr] gap-4 md:gap-6">
            <img
              src="/logos/straumann.png"
              alt="Straumann Group logo"
              class="w-12 h-12 md:w-16 md:h-16 rounded object-contain bg-white p-1"
              loading="lazy"
            />
            <div class="space-y-3">
              <div class="flex justify-between items-baseline gap-4 flex-wrap">
                <h3 class="text-xl md:text-2xl font-serif">Straumann Group</h3>
                <p class="text-xs tracking-widest text-stone-500 font-mono whitespace-nowrap">
                  2022 — 2025
                </p>
              </div>
              <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
                HealthTech · Medical Devices
              </p>
              <div class="space-y-1 text-sm pt-2">
                <span class="text-stone-200"
                  >Program Manager · Digital Transformation</span
                >
                <p class="text-stone-400 leading-relaxed">
                  Drove enterprise digital transformation programs across the
                  global organization, modernizing operations and unlocking new
                  capabilities at scale.
                </p>
              </div>
            </div>
          </div>

          <!-- Atmos Energy -->
          <div class="grid grid-cols-[60px_1fr] md:grid-cols-[80px_1fr] gap-4 md:gap-6">
            <img
              src="/logos/atmos.png"
              alt="Atmos Energy logo"
              class="w-12 h-12 md:w-16 md:h-16 rounded object-contain bg-white p-1"
              loading="lazy"
            />
            <div class="space-y-3">
              <div class="flex justify-between items-baseline gap-4 flex-wrap">
                <h3 class="text-xl md:text-2xl font-serif">Atmos Energy</h3>
                <p class="text-xs tracking-widest text-stone-500 font-mono whitespace-nowrap">
                  2019 — 2022
                </p>
              </div>
              <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
                Energy · Engineering, Procurement &amp; Construction
              </p>
              <div class="space-y-1 text-sm pt-2">
                <span class="text-stone-200"
                  >Project Manager · Capital Projects</span
                >
                <p class="text-stone-400 leading-relaxed">
                  Led capital project execution across one of the fastest-growing
                  service territories, coordinating engineering, procurement, and
                  construction at scale.
                </p>
              </div>
            </div>
          </div>

          <!-- FedEx -->
          <div class="grid grid-cols-[60px_1fr] md:grid-cols-[80px_1fr] gap-4 md:gap-6">
            <img
              src="/logos/fedex.png"
              alt="FedEx logo"
              class="w-12 h-12 md:w-16 md:h-16 rounded object-contain bg-white p-1"
              loading="lazy"
            />
            <div class="space-y-3">
              <div class="flex justify-between items-baseline gap-4 flex-wrap">
                <h3 class="text-xl md:text-2xl font-serif">FedEx</h3>
                <p class="text-xs tracking-widest text-stone-500 font-mono whitespace-nowrap">
                  2018 — 2019
                </p>
              </div>
              <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
                Logistics · Supply Chain
              </p>
              <div class="space-y-1 text-sm pt-2">
                <span class="text-stone-200"
                  >Industrial Engineer</span
                >
                <p class="text-stone-400 leading-relaxed">
                  Overhauled operational excellence programs across logistics
                  operations, applying Lean methodology to continuously improve
                  throughput and efficiency.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section> 

      <!-- § 05 WORK / CASE STUDIES -->
      <section id="work" class="space-y-8 pt-12 border-t border-stone-800">
        <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono">
          § 05 — Selected Work
        </p>
        <h2 class="text-3xl md:text-4xl font-serif leading-tight">
          Programs I've <em class="italic text-amber-400">shipped</em>.
        </h2>
        <div class="space-y-6 pt-4">
          <div class="border border-stone-800 p-6 md:p-8 space-y-4 hover:border-stone-700 transition">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              CASE STUDY 01 · [DOMAIN]
            </p>
            <h3 class="text-xl md:text-2xl font-serif">[Case study title]</h3>
            <div class="space-y-3 text-sm pt-2">
              <div>
                <span class="text-stone-500 uppercase tracking-widest text-xs font-mono">Problem</span>
                <p class="text-stone-300 mt-1 leading-relaxed">
                  [1-2 sentences describing the challenge.]
                </p>
              </div>
              <div>
                <span class="text-stone-500 uppercase tracking-widest text-xs font-mono">Approach</span>
                <p class="text-stone-300 mt-1 leading-relaxed">
                  [1-2 sentences on what you did and how you led the program.]
                </p>
              </div>
              <div>
                <span class="text-stone-500 uppercase tracking-widest text-xs font-mono">Outcome</span>
                <p class="text-stone-300 mt-1 leading-relaxed">
                  [Quantified result — XX% improvement, $XXM unblocked, [N] deals completed, etc.]
                </p>
              </div>
            </div>
          </div>

          <div class="border border-stone-800 p-6 md:p-8 space-y-4 hover:border-stone-700 transition">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              CASE STUDY 02 · [DOMAIN]
            </p>
            <h3 class="text-xl md:text-2xl font-serif">[Case study title]</h3>
            <div class="space-y-3 text-sm pt-2">
              <div>
                <span class="text-stone-500 uppercase tracking-widest text-xs font-mono">Problem</span>
                <p class="text-stone-300 mt-1 leading-relaxed">
                  [1-2 sentences describing the challenge.]
                </p>
              </div>
              <div>
                <span class="text-stone-500 uppercase tracking-widest text-xs font-mono">Approach</span>
                <p class="text-stone-300 mt-1 leading-relaxed">
                  [1-2 sentences on what you did.]
                </p>
              </div>
              <div>
                <span class="text-stone-500 uppercase tracking-widest text-xs font-mono">Outcome</span>
                <p class="text-stone-300 mt-1 leading-relaxed">
                  [Quantified result.]
                </p>
              </div>
            </div>
          </div>

          <div class="border border-stone-800 p-6 md:p-8 space-y-4 hover:border-stone-700 transition">
            <p class="text-xs tracking-widest text-stone-500 uppercase font-mono">
              CASE STUDY 03 · [DOMAIN]
            </p>
            <h3 class="text-xl md:text-2xl font-serif">[Case study title]</h3>
            <div class="space-y-3 text-sm pt-2">
              <div>
                <span class="text-stone-500 uppercase tracking-widest text-xs font-mono">Problem</span>
                <p class="text-stone-300 mt-1 leading-relaxed">
                  [1-2 sentences describing the challenge.]
                </p>
              </div>
              <div>
                <span class="text-stone-500 uppercase tracking-widest text-xs font-mono">Approach</span>
                <p class="text-stone-300 mt-1 leading-relaxed">
                  [1-2 sentences on what you did.]
                </p>
              </div>
              <div>
                <span class="text-stone-500 uppercase tracking-widest text-xs font-mono">Outcome</span>
                <p class="text-stone-300 mt-1 leading-relaxed">
                  [Quantified result.]
                </p>
              </div>
            </div>
          </div>
        </div>
        <p class="text-stone-500 text-sm pt-4 italic">
          Full case studies and outcomes available on request — <a
            href="#contact"
            class="text-stone-300 underline hover:text-amber-400 transition"
            >reach out</a
          >.
        </p>
      </section>

      <!-- § 06 CONTACT -->
      <section id="contact" class="space-y-8 pt-12 border-t border-stone-800">
        <p class="text-xs tracking-[0.3em] text-stone-500 uppercase font-mono">
          § 06 — Contact
        </p>
        <h2 class="text-3xl md:text-4xl font-serif leading-tight">
          Get in <em class="italic text-amber-400">touch</em>.
        </h2>
        <p class="text-stone-300 max-w-xl leading-relaxed">
          Open to new opportunities and, as always, continually improving.
        </p>

        <!-- Icon buttons -->
        <div class="flex gap-4 pt-2">
          <!-- LinkedIn -->
          <a
            href="https://linkedin.com/in/jackyyu1993"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="group flex items-center justify-center w-14 h-14 rounded-full border border-stone-700 hover:border-amber-400 hover:bg-stone-900 transition"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5 text-stone-400 group-hover:text-amber-400 transition"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              />
            </svg>
          </a>

          <!-- GitHub -->
          <a
            href="https://github.com/jackyyu93"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="group flex items-center justify-center w-14 h-14 rounded-full border border-stone-700 hover:border-amber-400 hover:bg-stone-900 transition"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5 text-stone-400 group-hover:text-amber-400 transition"
            >
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
              />
